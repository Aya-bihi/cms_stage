<div class="portail-forum-wrapper">
  <div class="forum-header">
    <h2 class="forum-titre">Forum</h2>
    {% if user and user.hasPermission('create forum_sujet content') %}
      <a href="{{ path('node.add', {node_type: 'forum_sujet'}) }}" class="button button--primary">
        + Nouveau sujet
      </a>
    {% endif %}
  </div>

  {% if sujets is not empty %}
    <table class="forum-table">
      <thead>
        <tr>
          <th>Sujet</th>
          <th>Catégorie</th>
          <th>Auteur</th>
          <th>Date</th>
          <th>Réponses</th>
        </tr>
      </thead>
      <tbody>
        {% for sujet in sujets %}
          <tr>
            <td>
              <a href="{{ path('portail_ministre.forum.detail', {nid: sujet.id}) }}">
                {{ sujet.titre }}
              </a>
            </td>
            <td>{{ sujet.categorie_label }}</td>
            <td>{{ sujet.auteur }}</td>
            <td>{{ sujet.date }}</td>
            <td>{{ sujet.nb_reponses }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="forum-vide">Aucun sujet pour le moment.</p>
  {% endif %}
</div>

<style>
.portail-forum-wrapper { padding: 1.5rem; }
.forum-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.2rem;
}
.forum-titre {
  font-size: 1.4rem;
  font-weight: 600;
  margin: 0;
}
.forum-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.95rem;
}
.forum-table thead tr {
  background-color: #1a3a5c;
  color: #fff;
}
.forum-table th, .forum-table td {
  padding: 10px 14px;
  text-align: left;
  border-bottom: 1px solid #e0e0e0;
}
.forum-table tbody tr:hover {
  background-color: #f4f6f9;
}
.forum-table a {
  color: #1a3a5c;
  font-weight: 500;
  text-decoration: none;
}
.forum-table a:hover { text-decoration: underline; }
.forum-vide { color: #888; font-style: italic; }
</style>