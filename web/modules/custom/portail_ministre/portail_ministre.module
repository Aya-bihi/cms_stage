/**
 * Implements hook_form_alter() pour Forum Reponse.
 */
function portail_ministre_form_node_forum_reponse_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  
  // Récupérer l'ID du sujet parent depuis l'URL
  $nid = \Drupal::request()->query->get('field_sujet_parent');
  
  if (!empty($nid)) {
    // Charger le nœud parent
    $node = \Drupal\node\Entity\Node::load($nid);
    
    if ($node) {
      // Remplir automatiquement le champ Sujet parent
      $form['field_sujet_parent']['widget'][0]['target_id']['#default_value'] = $node;
    }
  }
}