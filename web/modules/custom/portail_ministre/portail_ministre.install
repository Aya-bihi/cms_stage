 */
function portail_ministre_update_8001() {
  $spec = [
    'type' => 'varchar',
    'length' => 20,
    'not null' => TRUE,
    'default' => 'NORMALE',
    'description' => 'BASSE | NORMALE | HAUTE | URGENTE',
  ];
  \Drupal::database()
    ->schema()
    ->addField('portail_ministre_tache', 'priorite', $spec);
}

/**
 * Ajoute la colonne 'confidentiel' à portail_ministre_document.
 */
function portail_ministre_update_8002() {
  $spec = [
    'type' => 'int',
    'size' => 'tiny',
    'not null' => TRUE,
