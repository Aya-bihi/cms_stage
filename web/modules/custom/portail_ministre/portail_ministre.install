      'utilisateur_idx' => ['id_utilisateur'],
      'statut_idx' => ['statut'],
    ],
  ];

  // ============================================================
  // TABLE : portail_ministre_evenement
  // ============================================================
  $schema['portail_ministre_evenement'] = [
    'description' => 'Événements du calendrier ministériel.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'id_document' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => FALSE,
      ],
      'id_utilisateur' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'titre' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'contenu' => [
        'type' => 'text',
        'size' => 'normal',
        'not null' => FALSE,
      ],
      'date_debut' => [
        'type' => 'int',
        'not null' => FALSE,
      ],
      'date_fin' => [
        'type' => 'int',
        'not null' => FALSE,
      ],
      'statut' => [
        'type' => 'varchar',
        'length' => 50,
        'not null' => TRUE,
        'default' => 'PROGRAMME',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'utilisateur_idx' => ['id_utilisateur'],
      'date_idx' => ['date_debut'],
    ],
  ];

  // ============================================================
  // TABLE : portail_ministre_application
  // ============================================================
  $schema['portail_ministre_application'] = [
    'description' => 'Applications intégrées au portail ministériel.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'nom' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'url' => [
        'type' => 'varchar',
        'length' => 500,
        'not null' => FALSE,
      ],
      'description' => [
        'type' => 'text',
        'size' => 'normal',
        'not null' => FALSE,
      ],
      'id_utilisateur' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => FALSE,
        'description' => 'Responsable de l\'application.',
      ],
    ],
    'primary key' => ['id'],
  ];

  return $schema;
}

// ============================================================
// hook_uninstall
// ============================================================
/**
 * Implements hook_uninstall().
 */
function portail_ministre_uninstall() {
  $tables = [
    'portail_ministre_application',
    'portail_ministre_evenement',
    'portail_ministre_tache',
    'portail_ministre_sondage',
    'portail_ministre_message',
    'portail_ministre_agenda',
    'portail_ministre_actualite',
    'portail_ministre_notification',
    'portail_ministre_dispo_docs',
    'portail_ministre_demande',
    'portail_ministre_formulaire',
    'portail_ministre_workflow',
    'portail_ministre_journal_audit',
    'portail_ministre_note',
    'portail_ministre_version_document',
    'portail_ministre_document',
    'portail_ministre_groupe_utilisateur_map',
    'portail_ministre_groupe_utilisateur',
    'portail_ministre_permission',
    'portail_ministre_utilisateur',
    'portail_ministre_role',
    'portail_ministre_categorie_document',
    'portail_ministre_direction',
  ];

  $schema = \Drupal::database()->schema();
  foreach ($tables as $table) {
    if ($schema->tableExists($table)) {
      $schema->dropTable($table);
    }
  }
}

